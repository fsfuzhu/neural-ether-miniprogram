/**app.wxss - Neural Ether 水墨主题**/
page {
  --color-primary: #162839;
  --color-secondary: #b02d21;
  --color-tertiary: #112c1e;
  --color-background: #fbf9f4;
  --color-surface: #fbf9f4;
  --color-surface-container: #f0eee9;
  --color-surface-container-low: #f5f3ee;
  --color-surface-container-high: #eae8e3;
  --color-surface-container-highest: #e4e2dd;
  --color-surface-container-lowest: #ffffff;
  --color-on-surface-variant: #43474c;
  --color-outline-variant: #c4c6cd;

  background-color: var(--color-background);
  font-family: "PingFang SC", "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--color-primary);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* 纸质纹理背景 */
.paper-bg {
  background-color: var(--color-background);
  background-image:
    radial-gradient(circle at 10% 20%, rgba(22, 40, 57, 0.03) 0%, transparent 40%),
    radial-gradient(circle at 90% 80%, rgba(176, 45, 33, 0.02) 0%, transparent 40%);
}

/* 水墨晕染 */
.ink-bleed {
  background: radial-gradient(circle, rgba(22, 40, 57, 0.08) 0%, transparent 70%);
}

/* 玉色渐变 */
.jade-wash {
  background: linear-gradient(180deg, rgba(175, 206, 185, 0.12) 0%, rgba(175, 206, 185, 0.04) 100%);
}

/* 格纹背景 */
.lattice-pattern {
  background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 20 L40 20 M20 0 L20 40 M0 0 L40 40 M40 0 L0 40' fill='none' stroke='%23162839' stroke-width='0.5' stroke-opacity='0.05'/%3E%3C/svg%3E");
}

/* ---- 通用布局 ---- */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.self-end { align-self: flex-end; }
.flex-wrap { flex-wrap: wrap; }

/* ---- 间距 ---- */
.gap-sm { gap: 12rpx; }
.gap-md { gap: 24rpx; }
.gap-lg { gap: 40rpx; }

/* ---- 文字 ---- */
.font-headline {
  font-family: "Noto Serif SC", "PingFang SC", serif;
  font-weight: 700;
}

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-secondary); }
.text-tertiary { color: var(--color-tertiary); }
.text-muted { color: var(--color-on-surface-variant); opacity: 0.6; }
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }
.text-3xl { font-size: 56rpx; }
.text-4xl { font-size: 72rpx; }
.text-bold { font-weight: 700; }
.text-extrabold { font-weight: 800; }
.text-center { text-align: center; }
.tracking-wide { letter-spacing: 0.1em; }
.tracking-widest { letter-spacing: 0.2em; }
.uppercase { text-transform: uppercase; }
.leading-relaxed { line-height: 1.8; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ---- 圆角与阴影 ---- */
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded-2xl { border-radius: 32rpx; }
.rounded-full { border-radius: 50%; }
.shadow-sm { box-shadow: 0 2rpx 8rpx rgba(22, 40, 57, 0.04); }
.shadow-md { box-shadow: 0 8rpx 24rpx rgba(22, 40, 57, 0.06); }
.shadow-lg { box-shadow: 0 16rpx 48rpx rgba(22, 40, 57, 0.08); }

/* ---- 表面与卡片 ---- */
.surface-lowest {
  background-color: var(--color-surface-container-lowest);
}
.surface-low {
  background-color: var(--color-surface-container-low);
}
.surface-base {
  background-color: var(--color-surface-container);
}
.surface-high {
  background-color: var(--color-surface-container-high);
}
.surface-highest {
  background-color: var(--color-surface-container-highest);
}

.card {
  background-color: var(--color-surface-container-lowest);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(22, 40, 57, 0.04);
}

/* ---- 按钮 ---- */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-secondary);
  color: #ffffff;
  padding: 20rpx 48rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 26rpx;
  letter-spacing: 0.1em;
  box-shadow: 0 8rpx 24rpx rgba(176, 45, 33, 0.2);
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  color: var(--color-primary);
  padding: 20rpx 48rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 26rpx;
  border: 2rpx solid rgba(22, 40, 57, 0.2);
}

/* ---- 标签 ---- */
.tag {
  display: inline-flex;
  padding: 8rpx 24rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  background-color: var(--color-surface-container-high);
  color: var(--color-primary);
}

.tag-accent {
  background-color: rgba(176, 45, 33, 0.08);
  color: var(--color-secondary);
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-size: 20rpx;
}

/* ---- 分割线 ---- */
.divider {
  width: 100%;
  height: 1rpx;
  background-color: rgba(196, 198, 205, 0.15);
  margin: 24rpx 0;
}

/* ---- 动画 ---- */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.animate-pulse { animation: pulse 2s ease-in-out infinite; }
.animate-bounce { animation: bounce 1s ease-in-out infinite; }
