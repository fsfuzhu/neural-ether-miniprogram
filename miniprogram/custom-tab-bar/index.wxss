.tab-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background-color: rgba(251, 249, 244, 0.85);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(196, 198, 205, 0.1);
  box-shadow: 0 -4rpx 24rpx rgba(22, 40, 57, 0.04);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  transform: scale(1.08);
}

/* ---- 图标容器 ---- */
.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

/* ---- 对话图标 ---- */
.icon-chat {
  position: relative;
  width: 40rpx;
  height: 34rpx;
}
.chat-bubble {
  width: 40rpx;
  height: 30rpx;
  border: 3rpx solid rgba(22, 40, 57, 0.35);
  border-radius: 8rpx;
}
.chat-tail {
  position: absolute;
  bottom: -4rpx;
  left: 8rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid rgba(22, 40, 57, 0.35);
}
.icon-chat.icon-active .chat-bubble {
  border-color: #b02d21;
  background-color: rgba(176, 45, 33, 0.08);
}
.icon-chat.icon-active .chat-tail {
  border-top-color: #b02d21;
}

/* ---- 智能体图标 ---- */
.icon-agent {
  position: relative;
  width: 38rpx;
  height: 40rpx;
}
.agent-head {
  position: absolute;
  bottom: 0;
  left: 2rpx;
  width: 34rpx;
  height: 26rpx;
  border: 3rpx solid rgba(22, 40, 57, 0.35);
  border-radius: 8rpx;
}
.agent-antenna {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 3rpx;
  height: 12rpx;
  background-color: rgba(22, 40, 57, 0.35);
  border-radius: 2rpx;
}
.agent-antenna::after {
  content: '';
  position: absolute;
  top: -4rpx;
  left: -3rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: rgba(22, 40, 57, 0.35);
}
.agent-eye {
  position: absolute;
  bottom: 8rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background-color: rgba(22, 40, 57, 0.35);
}
.agent-eye.left { left: 10rpx; }
.agent-eye.right { right: 10rpx; }
.icon-agent.icon-active .agent-head { border-color: #b02d21; background-color: rgba(176, 45, 33, 0.08); }
.icon-agent.icon-active .agent-antenna { background-color: #b02d21; }
.icon-agent.icon-active .agent-eye { background-color: #b02d21; }

/* ---- 历史图标 ---- */
.icon-history {
  position: relative;
  width: 38rpx;
  height: 38rpx;
}
.history-circle {
  width: 34rpx;
  height: 34rpx;
  border: 3rpx solid rgba(22, 40, 57, 0.35);
  border-radius: 50%;
}
.history-hand-h {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 3rpx;
  background-color: rgba(22, 40, 57, 0.35);
  transform-origin: left center;
  transform: rotate(0deg);
}
.history-hand-m {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 3rpx;
  background-color: rgba(22, 40, 57, 0.35);
  transform-origin: left center;
  transform: rotate(-90deg);
}
.icon-history.icon-active .history-circle { border-color: #b02d21; }
.icon-history.icon-active .history-hand-h { background-color: #b02d21; }
.icon-history.icon-active .history-hand-m { background-color: #b02d21; }

/* ---- 我的图标 ---- */
.icon-me {
  position: relative;
  width: 36rpx;
  height: 40rpx;
}
.me-head {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid rgba(22, 40, 57, 0.35);
  border-radius: 50%;
}
.me-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 16rpx;
  border: 3rpx solid rgba(22, 40, 57, 0.35);
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  border-bottom: none;
}
.icon-me.icon-active .me-head { border-color: #b02d21; }
.icon-me.icon-active .me-body { border-color: #b02d21; }

/* ---- 文字标签 ---- */
.tab-label {
  font-size: 20rpx;
  color: rgba(22, 40, 57, 0.35);
  letter-spacing: 0.15em;
  font-weight: 500;
  margin-top: 2rpx;
}

.label-active {
  color: #b02d21;
  font-weight: 700;
}

/* ---- 活跃指示点 ---- */
.tab-dot {
  position: absolute;
  bottom: 10rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #b02d21;
}
