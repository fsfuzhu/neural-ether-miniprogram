.me-page {
  min-height: 100vh;
}
.me-scroll {
  height: 100vh;
}

/* ---- 用户资料卡 ---- */
.profile-section {
  padding: 40rpx 32rpx 20rpx;
}
.profile-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 64rpx 40rpx 48rpx;
  background-color: var(--color-surface-container-low);
  border-radius: 32rpx;
  border-bottom: 6rpx solid rgba(176, 45, 33, 0.08);
  overflow: hidden;
}
.profile-ink {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.5;
  pointer-events: none;
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}
.avatar-glow {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  background-color: var(--color-secondary);
  opacity: 0.15;
  filter: blur(16rpx);
}
.avatar-img {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-surface-container-lowest);
  box-shadow: 0 8rpx 24rpx rgba(22, 40, 57, 0.1);
}
.profile-name {
  display: block;
  font-size: 44rpx;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}
.profile-subtitle {
  display: block;
  font-size: 20rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.5;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 700;
}

/* ---- 功能菜单 ---- */
.menu-section {
  padding: 20rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  background-color: var(--color-surface-container-lowest);
  border-radius: 28rpx;
  border: 1rpx solid rgba(196, 198, 205, 0.08);
  box-shadow: 0 2rpx 8rpx rgba(22, 40, 57, 0.03);
}
.menu-item:active {
  background-color: var(--color-surface-container-low);
}
.menu-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background-color: var(--color-surface-container-high);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}
.menu-icon {
  font-size: 32rpx;
  color: var(--color-primary);
}
.menu-info {
  flex: 1;
}
.menu-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}
.menu-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.6;
}
.menu-arrow {
  font-size: 36rpx;
  color: var(--color-outline-variant);
  margin-left: 12rpx;
}

/* ---- 底部版本信息 ---- */
.footer-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 20rpx;
}
.footer-brand {
  font-size: 32rpx;
  color: var(--color-primary);
  font-style: italic;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}
.footer-version {
  font-size: 20rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.4;
  letter-spacing: 0.1em;
}
