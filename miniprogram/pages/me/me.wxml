<view class="me-page paper-bg">
  <scroll-view scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" class="me-scroll">
    <!-- 用户资料卡 -->
    <view class="profile-section">
      <view class="profile-card">
        <view class="ink-bleed profile-ink"></view>
        <!-- 头像 -->
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <view class="avatar-wrap">
            <view class="avatar-glow"></view>
            <image wx:if="{{userInfo.avatar}}" class="avatar-img" src="{{userInfo.avatar}}" mode="aspectFill" />
            <view wx:else class="avatar-placeholder">
              <text class="avatar-letter">{{userInfo.name[0] || 'U'}}</text>
            </view>
          </view>
          <text class="avatar-hint">点击更换头像</text>
        </button>
        <!-- 昵称 -->
        <view class="nickname-row">
          <input
            class="nickname-input font-headline"
            type="nickname"
            value="{{userInfo.name}}"
            placeholder="点击设置昵称"
            bindchange="onNicknameChange"
            bindblur="onNicknameChange"
          />
          <text class="nickname-edit-icon">✎</text>
        </view>
        <text class="profile-subtitle">{{userInfo.subtitle}}</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view
        wx:for="{{menuItems}}"
        wx:key="label"
        class="menu-item"
        bindtap="onMenuTap"
        data-index="{{index}}"
      >
        <view class="menu-icon-wrap">
          <text class="menu-icon">{{item.icon}}</text>
        </view>
        <view class="menu-info">
          <text class="menu-label">{{item.label}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="footer-info">
      <text class="footer-brand font-headline">Neural Ether</text>
      <text class="footer-version">v1.0.0 · Powered by CloudBase</text>
    </view>

    <view style="height: 320rpx;"></view>
  </scroll-view>
</view>
