.agent-page {
  min-height: 100vh;
  position: relative;
}
.agent-scroll {
  height: 100vh;
}

/* ---- 页面标题 ---- */
.page-header {
  padding: 40rpx 40rpx 20rpx;
}
.page-title {
  display: block;
  font-size: 56rpx;
  color: var(--color-primary);
  line-height: 1.15;
  letter-spacing: -0.02em;
}
.title-accent {
  width: 80rpx;
  height: 6rpx;
  background-color: var(--color-secondary);
  border-radius: 4rpx;
  margin: 24rpx 0;
}
.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.7;
  line-height: 1.7;
}

/* ---- 精选 Banner (已弃用) ---- */
.hero-section {
  padding: 24rpx 32rpx;
}
.hero-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  background-color: var(--color-surface-container-lowest);
  box-shadow: 0 16rpx 48rpx rgba(22, 40, 57, 0.08);
  border: 1rpx solid rgba(196, 198, 205, 0.1);
  height: 600rpx;
}
.hero-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.4;
}
.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to right, var(--color-background) 30%, rgba(251, 249, 244, 0.3) 70%, transparent 100%);
}
.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  height: 100%;
  padding: 48rpx;
  max-width: 85%;
}
.tag-accent {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  background-color: rgba(176, 45, 33, 0.08);
  color: var(--color-secondary);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.15em;
  margin-bottom: 24rpx;
  width: fit-content;
}
.hero-title {
  display: block;
  font-size: 48rpx;
  color: var(--color-primary);
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin-bottom: 20rpx;
}
.hero-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.7;
  margin-bottom: 32rpx;
}
.hero-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
}
.hero-link {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
  border-bottom: 3rpx solid rgba(22, 40, 57, 0.15);
  padding-bottom: 4rpx;
}

/* ---- 分类卡片 ---- */
.section {
  padding: 16rpx 32rpx;
}
.categories-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.category-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 40rpx;
  background-color: var(--color-surface-container-low);
  border-radius: 32rpx;
  border: 1rpx solid rgba(196, 198, 205, 0.05);
}
.category-card:active {
  background-color: var(--color-surface-container);
}
.category-info {
  flex: 1;
}
.category-title {
  display: block;
  font-size: 34rpx;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}
.category-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
}
.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(22, 40, 57, 0.12);
  flex-shrink: 0;
  margin-left: 24rpx;
}
.category-icon-text {
  font-size: 36rpx;
  color: #ffffff;
}

/* ---- 活跃智能体 ---- */
.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 32rpx;
  margin-top: 16rpx;
}
.section-title {
  display: block;
  font-size: 44rpx;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}
.section-accent-bar {
  width: 48rpx;
  height: 6rpx;
  background-color: var(--color-secondary);
  border-radius: 4rpx;
  margin-top: 8rpx;
}
.section-more {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(22, 40, 57, 0.5);
}

.agents-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.agent-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 36rpx;
  background-color: var(--color-surface-container-lowest);
  border-radius: 32rpx;
  border-bottom: 6rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(22, 40, 57, 0.04);
}
.agent-card:active {
  border-bottom-color: var(--color-secondary);
  transform: translateY(-4rpx);
}
.agent-avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}
.agent-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-surface-container-high);
}
.agent-badge {
  position: absolute;
  bottom: -4rpx;
  right: -8rpx;
  background-color: var(--color-secondary);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 3rpx solid #ffffff;
}
.agent-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}
.agent-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-on-surface-variant);
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.agent-btn {
  width: 100%;
  padding: 16rpx 0;
  background-color: var(--color-surface-container);
  border-radius: 20rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.agent-btn:active {
  background-color: var(--color-secondary);
  color: #ffffff;
}

/* ---- FAB ---- */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(17, 44, 30, 0.3);
  z-index: 50;
}
.fab:active {
  transform: scale(1.1);
}
.fab-icon {
  font-size: 52rpx;
  color: #ffffff;
  font-weight: 300;
  margin-top: -4rpx;
}
