.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  box-sizing: border-box;
}

/* ---- 模型指示器 ---- */
.model-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 12rpx 28rpx;
  margin: 20rpx auto 0;
  background-color: rgba(17, 44, 30, 0.06);
  border: 1rpx solid rgba(17, 44, 30, 0.1);
  border-radius: 60rpx;
  width: fit-content;
  backdrop-filter: blur(20rpx);
}
.model-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #112c1e;
}
.model-name {
  font-size: 20rpx;
  font-weight: 700;
  color: #112c1e;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.model-arrow {
  font-size: 22rpx;
  color: #112c1e;
  transition: transform 0.2s;
}
.arrow-up {
  transform: rotate(180deg);
}

/* ---- 模型下拉 ---- */
.model-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}
.model-dropdown {
  position: fixed;
  top: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 480rpx;
  background-color: var(--color-surface-container-lowest);
  border-radius: 32rpx;
  box-shadow: 0 24rpx 64rpx rgba(22, 40, 57, 0.12);
  border: 1rpx solid rgba(196, 198, 205, 0.1);
  padding: 16rpx;
  z-index: 200;
}
.model-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 24rpx;
}
.model-option:active {
  background-color: var(--color-surface-container-low);
}
.model-selected {
  background-color: rgba(176, 45, 33, 0.05);
}
.model-option-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.model-selected .model-option-name {
  color: var(--color-secondary);
}
.model-option-provider {
  display: block;
  font-size: 18rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.6;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-top: 4rpx;
}
.check-mark {
  font-size: 28rpx;
  color: var(--color-secondary);
  font-weight: 700;
}

/* ---- 消息列表 ---- */
.message-list {
  flex: 1;
  padding: 20rpx 32rpx;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.message-list::-webkit-scrollbar {
  display: none;
  width: 0 !important;
  height: 0 !important;
  background: transparent;
}
.message-list::-webkit-scrollbar-thumb {
  background: transparent;
}
.message-list::-webkit-scrollbar-track {
  background: transparent;
}

/* ---- 欢迎区域 ---- */
.welcome-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 80rpx;
}
.welcome-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-surface-container-low);
  border: 1rpx solid rgba(196, 198, 205, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.welcome-icon {
  font-size: 44rpx;
  color: rgba(22, 40, 57, 0.3);
}
.welcome-title {
  font-size: 48rpx;
  color: var(--color-primary);
  letter-spacing: 0.05em;
  margin-bottom: 16rpx;
}
.welcome-desc {
  font-size: 26rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.7;
  text-align: center;
  max-width: 500rpx;
  line-height: 1.7;
}

/* ---- 消息行 ---- */
.msg-row {
  margin-bottom: 48rpx;
  width: 100%;
  box-sizing: border-box;
}
.msg-ai {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.msg-ai .msg-bubble {
  max-width: 85%;
}
.msg-user {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.msg-user .msg-bubble {
  max-width: 85%;
}

/* ---- 发送者信息 ---- */
.msg-sender {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}
.sender-right {
  padding-right: 8rpx;
  padding-left: 0;
}
.sender-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}
.sender-icon {
  font-size: 20rpx;
  color: #ffffff;
}
.sender-name {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(22, 40, 57, 0.4);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* ---- 消息气泡 ---- */
.msg-bubble {
  padding: 36rpx;
  border-radius: 32rpx;
  word-break: break-word;
  overflow-wrap: break-word;
}
.bubble-ai {
  border-top-left-radius: 0;
  border-left: 2rpx solid rgba(17, 44, 30, 0.08);
}
.bubble-user {
  background-color: var(--color-surface-container-highest);
  border-top-right-radius: 0;
}
.msg-text {
  font-size: 28rpx;
  color: var(--color-primary);
  line-height: 1.8;
  word-break: break-word;
  overflow-wrap: break-word;
  white-space: normal;
}

/* ---- 流式响应 ---- */
.bubble-ai-rich {
  padding: 44rpx;
  border-radius: 32rpx;
  border-top-left-radius: 0;
  border-left: 2rpx solid rgba(17, 44, 30, 0.08);
}
.stream-title {
  display: block;
  font-size: 36rpx;
  color: var(--color-primary);
  margin-bottom: 24rpx;
}
.stream-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stream-card {
  padding: 28rpx;
  background-color: rgba(240, 238, 233, 0.5);
  border-radius: 20rpx;
  border: 1rpx solid rgba(196, 198, 205, 0.1);
}
.card-label {
  display: block;
  font-size: 18rpx;
  font-weight: 700;
  color: var(--color-secondary);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}
.card-text {
  font-size: 24rpx;
  color: var(--color-primary);
  line-height: 1.7;
}
.stream-trailing {
  display: block;
  font-size: 28rpx;
  color: var(--color-primary);
  line-height: 1.8;
  margin-bottom: 16rpx;
}

/* ---- 打字动画 ---- */
.typing-dots {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  animation: bounce 1s ease-in-out infinite;
}
.dot-1 { background-color: #112c1e; }
.dot-2 { background-color: rgba(17, 44, 30, 0.5); animation-delay: 0.15s; }
.dot-3 { background-color: rgba(17, 44, 30, 0.2); animation-delay: 0.3s; }

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* ---- 输入栏 ---- */
.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 200rpx;
  padding: 0 24rpx;
  z-index: 100;
}
.input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background-color: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 32rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 12rpx 48rpx rgba(22, 40, 57, 0.08);
  border: 1rpx solid rgba(196, 198, 205, 0.2);
}
.input-icon {
  font-size: 36rpx;
  color: rgba(22, 40, 57, 0.4);
  padding: 8rpx 16rpx;
}
.input-field {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-primary);
  padding: 16rpx 0;
}
.input-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
}
.icon-btn:active {
  background-color: var(--color-surface-container-high);
}
.icon-plus {
  font-size: 40rpx;
  color: rgba(22, 40, 57, 0.5);
}
.send-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: var(--color-secondary);
  color: #ffffff;
  padding: 16rpx 36rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(176, 45, 33, 0.2);
}
.send-disabled {
  opacity: 0.5;
  pointer-events: none;
}
.send-btn:active {
  opacity: 0.9;
  transform: scale(0.97);
}
.send-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.15em;
}
.send-arrow {
  font-size: 24rpx;
}

/* ---- 首次使用引导 ---- */
.setup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(22, 40, 57, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}
.setup-card {
  width: 620rpx;
  background-color: var(--color-surface-container-lowest);
  border-radius: 40rpx;
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 24rpx 80rpx rgba(22, 40, 57, 0.2);
}
.setup-title {
  font-size: 40rpx;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}
.setup-desc {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.6;
  text-align: center;
  margin-bottom: 48rpx;
}

/* 头像选择 */
.setup-avatar-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}
.setup-avatar-btn::after {
  display: none;
}
.setup-avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: var(--color-surface-container-high);
  border: 4rpx dashed var(--color-outline-variant);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.setup-avatar-img {
  width: 100%;
  height: 100%;
}
.setup-avatar-plus {
  font-size: 56rpx;
  color: var(--color-outline-variant);
  font-weight: 300;
}
.setup-avatar-hint {
  font-size: 20rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.4;
  margin-top: 12rpx;
}

/* 昵称输入 */
.setup-nickname-wrap {
  width: 100%;
  margin-bottom: 40rpx;
}
.setup-nickname-input {
  width: 100%;
  height: 88rpx;
  background-color: var(--color-surface-container-low);
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--color-primary);
  box-sizing: border-box;
}

/* 确认按钮 */
.setup-confirm {
  width: 100%;
  height: 88rpx;
  background-color: var(--color-secondary);
  color: #ffffff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  box-shadow: 0 8rpx 24rpx rgba(176, 45, 33, 0.2);
  margin-bottom: 20rpx;
}
.setup-confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}
.setup-confirm-disabled {
  opacity: 0.35;
  pointer-events: none;
}

/* 跳过 */
.setup-skip {
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
  opacity: 0.5;
  padding: 12rpx 0;
}

/* ---- 附件按钮 ---- */
.attach-btns {
  display: flex;
  gap: 4rpx;
}
.attach-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
}
.attach-btn:active {
  background-color: var(--color-surface-container-high);
}
.attach-icon {
  font-size: 32rpx;
}

/* ---- 待发送图片预览条 ---- */
.pending-image-bar {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background-color: var(--color-surface-container-low);
  border-radius: 20rpx;
}
.pending-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.pending-name {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-on-surface-variant);
}
.pending-remove {
  font-size: 32rpx;
  color: var(--color-outline-variant);
  padding: 8rpx 16rpx;
}
.pending-remove:active {
  color: var(--color-secondary);
}

/* ---- 消息中的图片 ---- */
.msg-image {
  width: 100%;
  max-width: 400rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}
