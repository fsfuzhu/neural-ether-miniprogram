function processInline(text) {
  if (!text) return '';
  // Bold: **text**
  text = text.replace(getRegExp('\\*\\*(.+?)\\*\\*', 'g'), '<strong>$1</strong>');
  // Italic: *text* (but not inside **)
  text = text.replace(getRegExp('(?<!\\*)\\*([^*]+?)\\*(?!\\*)', 'g'), '<em>$1</em>');
  // Inline code: `text`
  text = text.replace(getRegExp('`([^`]+?)`', 'g'), '<code style="background:#f0eee9;padding:2px 6px;border-radius:4px;font-size:13px;">$1</code>');
  return text;
}

function parse(text) {
  if (!text) return '';

  var lines = text.split('\n');
  var result = [];
  var inList = false;

  for (var i = 0; i < lines.length; i++) {
    var line = lines[i];
    var trimmed = line.replace(getRegExp('^\\s+', ''), '');

    // Heading ###
    if (trimmed.indexOf('### ') === 0) {
      result.push('<div style="font-weight:700;font-size:15px;margin:12px 0 4px;color:#162839;">' + processInline(trimmed.substring(4)) + '</div>');
    }
    // Heading ##
    else if (trimmed.indexOf('## ') === 0) {
      result.push('<div style="font-weight:700;font-size:16px;margin:14px 0 4px;color:#162839;">' + processInline(trimmed.substring(3)) + '</div>');
    }
    // Heading #
    else if (trimmed.indexOf('# ') === 0) {
      result.push('<div style="font-weight:700;font-size:17px;margin:16px 0 6px;color:#162839;">' + processInline(trimmed.substring(2)) + '</div>');
    }
    // Unordered list: - item or * item
    else if (trimmed.indexOf('- ') === 0 || trimmed.indexOf('* ') === 0) {
      result.push('<div style="padding-left:16px;margin:3px 0;">• ' + processInline(trimmed.substring(2)) + '</div>');
    }
    // Ordered list: 1. item
    else if (getRegExp('^\\d+\\.\\s').test(trimmed)) {
      var dotIdx = trimmed.indexOf('. ');
      var num = trimmed.substring(0, dotIdx);
      result.push('<div style="padding-left:16px;margin:3px 0;">' + num + '. ' + processInline(trimmed.substring(dotIdx + 2)) + '</div>');
    }
    // Empty line
    else if (trimmed === '') {
      result.push('<div style="height:10px;"></div>');
    }
    // Normal text
    else {
      result.push('<div style="margin:2px 0;">' + processInline(trimmed) + '</div>');
    }
  }

  return result.join('');
}

module.exports = {
  parse: parse
};
