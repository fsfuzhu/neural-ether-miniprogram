<view class="chat-page paper-bg">

  <!-- 首次使用引导弹窗 -->
  <view wx:if="{{showSetup}}" class="setup-overlay">
    <view class="setup-card">
      <text class="setup-title font-headline">欢迎使用 Neural Ether</text>
      <text class="setup-desc">设置你的头像和昵称，开始智能对话之旅</text>

      <!-- 选择头像 -->
      <button class="setup-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onSetupAvatar">
        <view class="setup-avatar-circle">
          <image wx:if="{{setupAvatar}}" class="setup-avatar-img" src="{{setupAvatar}}" mode="aspectFill" />
          <text wx:else class="setup-avatar-plus">+</text>
        </view>
        <text class="setup-avatar-hint">点击选择头像</text>
      </button>

      <!-- 输入昵称 -->
      <view class="setup-nickname-wrap">
        <input
          class="setup-nickname-input"
          type="nickname"
          placeholder="点击输入昵称（自动填充微信昵称）"
          placeholder-style="color: rgba(22,40,57,0.3); font-size: 26rpx;"
          value="{{setupName}}"
          bindchange="onSetupNickname"
          bindinput="onSetupNicknameInput"
        />
      </view>

      <!-- 确认按钮 -->
      <view class="setup-confirm {{setupAvatar && setupName ? '' : 'setup-confirm-disabled'}}" bindtap="onSetupConfirm">
        <text>开始使用</text>
      </view>

      <!-- 跳过 -->
      <text class="setup-skip" bindtap="onSetupSkip">稍后设置</text>
    </view>
  </view>
  <!-- 模型指示器 -->
  <view class="model-indicator" bindtap="toggleModelPicker">
    <view class="model-dot animate-pulse"></view>
    <text class="model-name">{{selectedModel.name}}</text>
    <text class="model-arrow {{showModelPicker ? 'arrow-up' : ''}}">▾</text>
  </view>

  <!-- 模型选择下拉 -->
  <view wx:if="{{showModelPicker}}" class="model-overlay" bindtap="closeModelPicker"></view>
  <view wx:if="{{showModelPicker}}" class="model-dropdown">
    <view
      wx:for="{{models}}"
      wx:key="id"
      class="model-option {{selectedModel.id === item.id ? 'model-selected' : ''}}"
      data-index="{{index}}"
      bindtap="selectModel"
    >
      <view>
        <text class="model-option-name">{{item.name}}</text>
        <text class="model-option-provider">{{item.provider}}</text>
      </view>
      <text wx:if="{{selectedModel.id === item.id}}" class="check-mark">✓</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    scroll-into-view="{{toView}}"
    scroll-with-animation="true"
  >
    <!-- 空状态 -->
    <view wx:if="{{messages.length === 0}}" class="welcome-area">
      <view class="welcome-icon-wrap">
        <text class="welcome-icon">✦</text>
      </view>
      <text class="welcome-title font-headline">{{agentName}}</text>
      <text class="welcome-desc">墨色流转间，智慧自然呈现。请问今天有什么可以帮您的？</text>
    </view>

    <!-- 消息循环 -->
    <block wx:for="{{messages}}" wx:key="index">
      <!-- AI 消息 -->
      <view wx:if="{{item.role === 'ai'}}" class="msg-row msg-ai" id="msg-{{index}}">
        <view class="msg-sender">
          <view class="sender-avatar">
            <text class="sender-icon">✦</text>
          </view>
          <text class="sender-name">{{agentName}}</text>
        </view>
        <view class="msg-bubble bubble-ai jade-wash">
          <rich-text wx:if="{{item.html}}" class="msg-text" nodes="{{item.html}}"></rich-text>
          <text wx:elif="{{item.content}}" class="msg-text">{{item.content}}</text>
          <view wx:if="{{item.isStreaming}}" class="typing-dots">
            <view class="dot dot-1"></view>
            <view class="dot dot-2"></view>
            <view class="dot dot-3"></view>
          </view>
        </view>
      </view>

      <!-- 用户消息 -->
      <view wx:elif="{{item.role === 'user'}}" class="msg-row msg-user" id="msg-{{index}}">
        <view class="msg-sender sender-right">
          <text class="sender-name">{{userName}}</text>
        </view>
        <view class="msg-bubble bubble-user">
          <image wx:if="{{item.image}}" class="msg-image" src="{{item.image}}" mode="widthFix" bindtap="onPreviewImage" data-url="{{item.image}}" />
          <text wx:if="{{item.content}}" class="msg-text">{{item.content}}</text>
        </view>
      </view>
    </block>

    <view id="msg-bottom" style="height: {{keyboardHeight > 0 ? keyboardHeight + 120 + 'px' : '520rpx'}};"></view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar" style="bottom: {{keyboardHeight > 0 ? keyboardHeight + 'px' : '200rpx'}};">
    <!-- 图片预览条 -->
    <view wx:if="{{pendingImage}}" class="pending-image-bar">
      <image class="pending-thumb" src="{{pendingImage}}" mode="aspectFill" />
      <text class="pending-name">已选择图片</text>
      <text class="pending-remove" bindtap="onRemovePending">✕</text>
    </view>
    <view class="input-wrap">
      <view class="attach-btns">
        <view class="attach-btn" bindtap="onChooseImage">
          <text class="attach-icon">🖼</text>
        </view>
        <view class="attach-btn" bindtap="onChooseFile">
          <text class="attach-icon">📎</text>
        </view>
      </view>
      <input
        class="input-field"
        placeholder="输入消息..."
        placeholder-style="color: rgba(22, 40, 57, 0.25);"
        value="{{inputValue}}"
        bindinput="onInputChange"
        bindconfirm="onSend"
        disabled="{{isLoading}}"
        adjust-position="{{false}}"
        bindkeyboardheightchange="onKeyboardHeight"
      />
      <view class="input-actions">
        <view class="send-btn {{isLoading ? 'send-disabled' : ''}}" bindtap="onSend">
          <text class="send-text">{{isLoading ? '...' : '发送'}}</text>
          <text wx:if="{{!isLoading}}" class="send-arrow">→</text>
        </view>
      </view>
    </view>
  </view>
</view>
