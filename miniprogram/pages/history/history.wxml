<view class="history-page paper-bg">
  <scroll-view scroll-y="true" enhanced="true" show-scrollbar="false" class="history-scroll">
    <!-- 页面标题 -->
    <view class="page-header">
      <text class="page-title font-headline">对话记录</text>
      <view class="title-accent"></view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{conversations.length === 0}}" class="empty-state">
      <text class="empty-icon">◷</text>
      <text class="empty-title">暂无对话记录</text>
      <text class="empty-desc">开始一段新的对话，记录将自动保存于此。</text>
    </view>

    <!-- 对话列表 -->
    <view class="conv-list">
      <view
        wx:for="{{conversations}}"
        wx:key="id"
        class="conv-item"
        bindtap="onResume"
        data-id="{{item.id}}"
      >
        <view class="conv-avatar">
          <text class="conv-avatar-icon">✦</text>
        </view>
        <view class="conv-info">
          <view class="conv-top-row">
            <text class="conv-agent-name">{{item.agentName}}</text>
            <text class="conv-model">{{item.modelName}}</text>
          </view>
          <text class="conv-preview">{{item.lastMessage}}</text>
          <text class="conv-meta">{{item.messages.length}}条消息</text>
        </view>
        <view class="conv-actions">
          <view
            class="conv-delete"
            catchtap="onDelete"
            data-id="{{item.id}}"
          >
            <text class="delete-icon">×</text>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 320rpx;"></view>
  </scroll-view>
</view>
